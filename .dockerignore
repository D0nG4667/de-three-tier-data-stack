# ==============================================================================
# Bristol Air Quality Data Stack - Docker Build Ignore Patterns
# ==============================================================================
# Prevents bloated container contexts, credential leaks, and cache collisions.

# 1. Version Control & Metadata
.git
.gitignore
.gitattributes
.github
.agents

# 2. Local Environment & Package Managers
.venv
venv
env
.uv

# 3. Large Datasets & Cached Telemetry
data/*.csv
data/*.zip
data/Air_Quality_Continuous.csv
data/pipeline.log

# 4. Local Development & Testing Caches
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.ruff_cache
.tox
.coverage
htmlcov
scratch

# 5. Secrets & Credentials
.env
.env.*
!.env.example

# 6. dbt Build Artifacts & Logs
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/dbt_modules/
dbt_project/.user.yml
