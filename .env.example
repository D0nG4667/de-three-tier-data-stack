# ==============================================================================
# Bristol Air Quality Data Stack - Enterprise Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' in the project root and customize database credentials.
# Do NOT commit the active '.env' file containing production credentials to VCS.

# ------------------------------------------------------------------------------
# 1. Tier-1 Database Configuration (Raw Landing Store)
# ------------------------------------------------------------------------------
# Database name, master username, and password for the raw landing Postgres DB.
RAW_DB_NAME=bristol_raw
RAW_DB_USER=postgres
RAW_DB_PASSWORD=postgres_raw_password

# ------------------------------------------------------------------------------
# 2. Tier-2 Database Configuration (Analytical OLAP Warehouse)
# ------------------------------------------------------------------------------
# Database name, master username, and password for the transformed OLAP Postgres DB.
OLAP_DB_NAME=bristol_olap
OLAP_DB_USER=postgres
OLAP_DB_PASSWORD=postgres_olap_password

# ------------------------------------------------------------------------------
# 3. Tier-3 Database Configuration (MongoDB Document Store Cache)
# ------------------------------------------------------------------------------
# Root administrative credentials and database name for the MongoDB Speed Layer.
# Note: Root credentials are required for the initial setup.
NOSQL_DB_ROOT_USER=root
NOSQL_DB_ROOT_PASSWORD=mongo_root_password
NOSQL_DB_NAME=bristol_nosql

# ------------------------------------------------------------------------------
# 4. Observability and Monitoring Dashboards
# ------------------------------------------------------------------------------
# Authentication details for pgAdmin 4 web console.
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# ------------------------------------------------------------------------------
# 5. Dagster Cloud Integration
# ------------------------------------------------------------------------------
# Your personal Docker Hub username, used to automatically prep container tags.
DOCKER_USERNAME=your_docker_username

# The API Token generated from Dagster Cloud for running the local hybrid agent.
DAGSTER_CLOUD_API_TOKEN=your_dagster_cloud_agent_token
